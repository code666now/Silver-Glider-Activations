# --- Database (shared Postgres with the ticketing app; tables prefixed sg_) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Runtime ---
PORT=3000
NODE_ENV=production

# --- Public URL (used for QR codes and email links) ---
# Resolved by frontendUrl() in backend/lib/urls.js with priority:
#   FRONTEND_URL -> RAILWAY_BASE_URL -> RAILWAY_PUBLIC_DOMAIN
# CRITICAL: QR codes encode this URL. Do not print booth QRs until the final
# frontend domain is live and FRONTEND_URL points to it.
FRONTEND_URL=https://your-service.up.railway.app
RAILWAY_BASE_URL=https://your-service.up.railway.app
RAILWAY_PUBLIC_DOMAIN=your-service.up.railway.app

# --- Admin auth (independent of the ticketing app's JWT) ---
ACTIVATIONS_ADMIN_PASS=change-me
ACTIVATIONS_ADMIN_SECRET=change-me-to-a-long-random-string
# Where "new booth registered" notifications go:
ACTIVATIONS_ADMIN_NOTIFY_EMAIL=rosewoodmarketin@gmail.com

# --- Cloudinary (booth photo uploads) — set real values, never commit them ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Resend (booth confirmation / welcome emails) ---
RESEND_API_KEY=rvDm@s&ffFvG2kF
RESEND_FROM=activations@silverglidertix.com

